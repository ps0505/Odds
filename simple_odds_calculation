def handle_four_way():
    first_line = input('Enter the first line (ex. 5.5 Ks): ')
    second_line = input('Enter the second line (ex. 3.5 ER): ')
    interpret_type = input('Enter input method. 1 for singles, 2 for combined: ')

    # Initialize dictionaries to store odds
    mgm_odds_dict = {}
    devig_book_odds_dict = {}

    # Define combinations
    combinations = [
        f'o{first_line} & o{second_line}',
        f'o{first_line} & u{second_line}',
        f'u{first_line} & u{second_line}',
        f'u{first_line} & o{second_line}'
    ]

    if (interpret_type == '1'):
        # Get odds for each combination
        for combo in combinations:
            mgm_odds, devig_book_odds = get_odds_input(combo)
            mgm_odds_dict[combo] = mgm_odds
            devig_book_odds_dict[combo] = devig_book_odds

    else:
        # Get all odds together
        all_mgm_odds, all_devig_book_odds = get_all_odds_input()

        # Set the dictionaries using zip, which pairs elements at each index from two tuples
        for key, value in zip(combinations, all_mgm_odds.split('/')):
            mgm_odds_dict[key] = value
        for key, value in zip(combinations, all_devig_book_odds.split('/')):
            devig_book_odds_dict[key] = value
            
    # Format the output
    for key in mgm_odds_dict:
        devig_book_remaining = [odds for odds_key, odds in devig_book_odds_dict.items() if odds_key != key]
        devig_book_formatted = f'{devig_book_odds_dict[key]}/{devig_book_remaining[0]}/{devig_book_remaining[1]}/{devig_book_remaining[2]}'
        print(f'{key} MGM odds: {mgm_odds_dict[key]} Devig Book odds: {devig_book_formatted}')
        devig_cno_api(mgm_odds_dict[key], devig_book_formatted)

