from devigger_helper import devig_cno_api

def get_odds_input(label):
    mgm_odds = input(f'Enter the odds for {label} on MGM: ')
    devig_book_odds = input(f'Enter the odds for {label} on Devig Book: ')
    return mgm_odds, devig_book_odds

def get_all_odds_input():
    all_mgm_odds = input('Enter the odds for MGM in o&o,o&u,u&u,u&o order (ex. 120/340/200/500): ')
    all_devig_book_odds = input('Enter the odds for devig book in o&o,o&u,u&u,u&o order (ex. 120/340/200/500): ')
    return all_mgm_odds, all_devig_book_odds

def handle_four_way():
    first_line = input('Enter the first line (ex. 5.5 Ks): ')
    second_line = input('Enter the second line (ex. 3.5 ER): ')
    interpret_type = input('Enter input method. 1 for singles, 2 for combined: ')

    # Initialize dictionaries to store odds
    target_book_odds_dict = {}
    sharp_book_odds_dict = {}

    # Define combinations
    combinations = [
        f'o{first_line} & o{second_line}',
        f'o{first_line} & u{second_line}',
        f'u{first_line} & u{second_line}',
        f'u{first_line} & o{second_line}'
    ]

    if (interpret_type == '1'):
        # Get odds for each combination
        for combo in combinations:
            target_book_odds, sharp_book_odds = get_odds_input(combo)
            target_book_odds_dict[combo] = target_book_odds
            sharp_book_odds_dict[combo] = sharp_book_odds

    else:
        # Get all odds together
        all_target_book_odds, all_sharp_book_odds = get_all_odds_input()

        # Set the dictionaries using zip, which pairs elements at each index from two tuples
        for key, value in zip(combinations, all_target_book_odds.split('/')):
            target_book_odds_dict[key] = value
        for key, value in zip(combinations, all_sharp_book_odds.split('/')):
            sharp_book_odds_dict[key] = value
            
    # Format the output
    for key in target_book_odds_dict:
        devig_book_remaining = [odds for odds_key, odds in sharp_book_odds_dict.items() if odds_key != key]
        devig_book_formatted = f'{sharp_book_odds_dict[key]}/{devig_book_remaining[0]}/{devig_book_remaining[1]}/{devig_book_remaining[2]}'
        print(f'{key} MGM odds: {target_book_odds_dict[key]} Devig Book odds: {devig_book_formatted}')
        
        result = devig_cno_api(target_book_odds_dict[key], devig_book_formatted)
        
        if result['success']:
            data = result['data']
            print(f'Leg#1 ({data["leg1_odds"]}); Market Juice = {data["market_juice_percentage_formatted"]}; Fair Value = {data["fair_value_odds_formatted"]} ({data["fair_value_percentage_formatted"]})')
            print(f'Final Odds ({data["final_odds"]})')
            print(f'Summary; EV% = {data["ev_percentage_formatted"]}, Kelly Units = {data["kelly_quarter_unit"]:.2f}u, Kelly Wager = ${data["kelly_wager"]:.2f} (FB = {data["fb_percentage_formatted"]})\n')
            
            if data['ev_percentage'] < 0:
                print(f'Negative EV {data["ev_percentage_formatted"]} {data["fair_value_odds_formatted"]}\n')
        else:
            print(f'Error: {result["error"]}\n')

def handle_multi_way():
    sharp_odds = input('Enter the sharp odds separated by slashes (ex. 120/340/200/500/...): ')
    # keeping odds together for now
    devig_book_odds = input('Enter the devig book odds separated by slashes (ex. 120/340/200/500/...): ')

def main():
    # Get comparison type from user
    comparison_type = input('Select comparison type:\n1. Two lines (4-way comparison)\n2. More than two lines (multi-way comparison)\nEnter choice (1 or 2): ')
    if comparison_type == '1':
        handle_four_way()
    elif comparison_type == '2':
        handle_multi_way()
    else:
        print('Invalid choice. Please enter 1 or 2.')
        main()

if __name__ == '__main__':
    main()